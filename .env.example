# ===========================================
# Шаблон файла настроек для AgroPrice API
# ===========================================
# Скопируйте этот файл в .env и заполните значения
# Команда: cp .env.example .env

# ───────────────────────────────────────────
# База данных (PostgreSQL)
# ───────────────────────────────────────────
DB_USER=agro_user
DB_PASSWORD=change_this_in_prod
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agro_kuban

# ───────────────────────────────────────────
# Безопасность (JWT токены)
# ───────────────────────────────────────────
# Сгенерируйте случайную строку для продакшена!
# Можно использовать: openssl rand -hex 32
SECRET_KEY=change_this_to_secure_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ───────────────────────────────────────────
# Настройки приложения
# ───────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
